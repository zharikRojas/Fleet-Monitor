{
  "ConnectionStrings": {
    "DefaultConnection": "Host={DB_HOST_DEV};Port={DB_PORT_DEV};Database={DB_NAME_DEV};Username={DB_USER_DEV};Password={DB_PASSWORD_DEV}"
  },
  "Jwt": {
    "SecretKey": "{JWT_SECRET_KEY}",
    "Issuer": "{JWT_ISSUER}",
    "Audience": "{JWT_AUDIENCE}",
    "ExpirationMinutes": "{JWT_EXPIRATION_MINUTES}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
